# Clerk
# Clerk publishable key (required)
VITE_CLERK_PUBLISHABLE_KEY=

# Shopify
# Your store's myshopify.com domain. Defaults to Shopify's public Hydrogen demo store.
SHOPIFY_STORE_DOMAIN=
# Storefront API version (e.g. 2026-01).
SHOPIFY_STOREFRONT_API_VERSION=
# Public Storefront API token. Defaults to Shopify's public Hydrogen demo token.
SHOPIFY_PUBLIC_STOREFRONT_TOKEN=
# Optional private Storefront API token. Higher rate limits + buyer-IP forwarding when set.
SHOPIFY_PRIVATE_STOREFRONT_TOKEN=
# Customer Account API client ID. Required when customerAccount=enabled.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
# Numeric Shop ID (Shopify admin > Settings > Customer accounts). Required when customerAccount=enabled.
SHOPIFY_CUSTOMER_ACCOUNT_SHOP_ID=
# OAuth callback URL. Defaults to http://localhost:3000/shop/account/callback.
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=
# 32+ char secret used to sign customer session cookies. Required when customerAccount=enabled.
SHOPIFY_SESSION_SECRET=
